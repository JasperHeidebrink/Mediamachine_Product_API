<div class="s-grid s-grid--responsive c-event-filter">

    <div class="s-grid__column s-grid__column--4-12">
        <label for="event_filter_text">Zoek</label>
        <input type="text"
               placeholder="zoeken"
               name="shop_filter_text">
    </div>

    <div class="s-grid__column s-grid__column--4-12">
        <label for="event_filter_activity">Categorie</label>
        <select name="event_filter_activity">
            <option value="0">Alle</option>
            {% for category in categories %}
                <option value="{{ category }}"
                        {% if active_activity == category_name %}selected="selected"{% endif %}
                >{{ category|capitalize }}</option>
            {% endfor %}
        </select>
    </div>

</div>

<div class="s-grid c-event-activities">
    {% if shops and shops is iterable %}
        {% for shop in shops %}
            <div class="event__block s-grid__column s-grid__column--4-12"
                 data-category="{{ shop.branches|join(' ') }}">

                <div class="s-square">
                    <div class="s-square__content">
                        <div class="c-card">
                            <a href="{{ shop.url }}">
                                <div class="c-card__image"
                                     style="background-image: url('{{ shop.image | default(default_image) }}');"></div>
                            </a>

                            <div class="c-card__title ">
                                <small>Locatie: {{ shop.stand.sublocation }}</small>
                                <p class="c-article__title h3">
                                    {{ shop.title }}
                                </p>

                                <a href="{{ shop.url }}" type="button" class="c-button c-button--card" target="_blank">Website</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    {% endif %}

</div>